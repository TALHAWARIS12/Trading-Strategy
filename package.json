{
  "name": "crypto-paper-trading-bot",
  "version": "1.0.0",
  "description": "Production-grade crypto paper trading system with Binance WebSockets",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node src/app.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/app.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "stop:pm2": "pm2 stop trading-bot",
    "restart:pm2": "pm2 restart trading-bot",
    "logs:pm2": "pm2 logs trading-bot",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "backtest": "ts-node src/scripts/backtest.ts",
    "reset-paper": "ts-node src/scripts/reset-paper-account.ts",
    "validate-strategy": "ts-node src/scripts/validate-strategy.ts"
  },
  "keywords": [
    "trading",
    "crypto",
    "binance",
    "websocket",
    "real-time",
    "paper-trading"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pm2": "^5.3.0",
    "sqlite3": "^5.1.6",
    "technicalindicators": "^3.1.0",
    "winston": "^3.11.0",
    "ws": "^8.15.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
